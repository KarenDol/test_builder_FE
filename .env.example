# FastAPI base URL (no trailing slash). Required for static export — inlined at build time.
NEXT_PUBLIC_API_URL=https://bedutest.narxoz.kz

# Production UI is served at https://ne.edutest.narxoz.kz — the API must set PUBLIC_APP_BASE_URL there for email links.

# --- Student email verification (NOT configured here) ---
# Sign-up sends mail from the **backend** (Python API). Copy variables from the API’s `.env.example`:
#   repo: test_builder_BE/.env.example — set SMTP_HOST, SMTP_FROM, SMTP_USER, SMTP_PASSWORD, and
#   PUBLIC_APP_BASE_URL=https://ne.edutest.narxoz.kz (your live frontend, used inside the link in the email).

# Optional: Google Sign-In on the login page (OAuth 2.0 Web client ID). Must match GOOGLE_OAUTH_CLIENT_ID on the API.
# In Google Cloud Console → APIs & Services → Credentials → create OAuth client ID (Web application).
# Authorized JavaScript origins: e.g. http://localhost:3000 and https://ne.edutest.narxoz.kz
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
